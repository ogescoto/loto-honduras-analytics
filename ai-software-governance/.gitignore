# Secretos y entorno (NUNCA versionar valores reales)
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# Editores / IDE
.idea/
.vscode/
*.swp
*~

# Artefactos / temporales
__pycache__/
*.pyc
.cache/
node_modules/
dist/
build/
