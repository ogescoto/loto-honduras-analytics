# =====================================================================
# EJEMPLO de .env.example
# Copia a la raíz del proyecto como ".env.example" (versionado) y crea
# tu ".env" local (NO versionado) con valores reales.
# Reglas: ../08_DevOps/Secrets_Management.md y ../08_DevOps/Environments.md
# NUNCA pongas secretos reales en este archivo de ejemplo.
# =====================================================================

# --- Aplicación ---
APP_ENV=local                 # local | test | staging | production
APP_PORT=3000
APP_BASE_URL=http://localhost:3000

# --- Base de datos ---
DATABASE_URL=postgres://user:pass@localhost:5432/app_dev

# --- Autenticación ---
JWT_SECRET=change-me-in-real-env
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# --- Servicios externos (usar SIEMPRE claves de TEST en local) ---
STRIPE_API_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxx

# --- Observabilidad ---
LOG_LEVEL=debug               # debug | info | warn | error
