---
import Shell from "../layouts/Shell.astro";

// Pantalla Admin: registro de cobros presenciales (admin/clerk).
// El formulario hace POST autenticado a la Edge API desde el navegador.
const apiBase = import.meta.env.PUBLIC_API_BASE_URL ?? "http://localhost:8787";
---

<Shell title="Cobros presenciales" active="admin">
  <p class="mb-6 text-slate-600">
    Registra una suscripción pagada en efectivo en ventanilla. Requiere rol
    <strong>admin</strong> o <strong>clerk</strong>.
  </p>

  <form id="cobro-form" class="space-y-4 rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
    <label class="block">
      <span class="text-sm font-medium">Email del cliente</span>
      <input name="clientEmail" type="email" required
        class="mt-1 w-full rounded border border-slate-300 px-3 py-2" />
    </label>
    <label class="block">
      <span class="text-sm font-medium">Meses de validez</span>
      <input name="validityMonths" type="number" min="1" value="1" required
        class="mt-1 w-full rounded border border-slate-300 px-3 py-2" />
    </label>
    <label class="block">
      <span class="text-sm font-medium">Número de recibo físico</span>
      <input name="paperReceiptNumber" type="text" required
        class="mt-1 w-full rounded border border-slate-300 px-3 py-2" />
    </label>
    <button type="submit"
      class="rounded bg-brand px-4 py-2 font-semibold text-white hover:bg-brand-dark">
      Registrar cobro
    </button>
    <p id="result" class="text-sm" role="status"></p>
  </form>

  <script is:inline define:vars={{ apiBase }}>
    const form = document.getElementById("cobro-form");
    const result = document.getElementById("result");
    let submitting = false;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (submitting) return; // anti doble-click
      submitting = true;

      const token = document.cookie
        .split("; ")
        .find((c) => c.startsWith("loto_token="))
        ?.split("=")[1];

      const data = Object.fromEntries(new FormData(form).entries());
      data.validityMonths = Number(data.validityMonths);

      try {
        const res = await fetch(`${apiBase}/api/v1/admin/register-physical-payment`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            ...(token ? { Authorization: `Bearer ${token}` } : {}),
          },
          body: JSON.stringify(data),
        });
        const body = await res.json();
        if (body.success) {
          result.textContent = body.data.message;
          result.className = "text-sm text-emerald-700";
          form.reset();
        } else {
          result.textContent = body.error.message;
          result.className = "text-sm text-red-600";
        }
      } catch {
        result.textContent = "Error de red al registrar el cobro.";
        result.className = "text-sm text-red-600";
      } finally {
        submitting = false;
      }
    });
  </script>
</Shell>
