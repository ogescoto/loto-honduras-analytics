# =====================================================================
# .gitignore — Loto Honduras Analytics
# Regla mandatory: ningún secreto en el repo.
# ai-software-governance/08_DevOps/Secrets_Management.md
# =====================================================================

# --- Secretos y entorno ---
.env
.env.*
!.env.example
*.pem
*.key
# secretos locales de wrangler (en la raíz o en cualquier app)
.dev.vars
**/.dev.vars

# --- Dependencias ---
node_modules/
.pnpm-store/

# --- Build / output ---
dist/
build/
.output/
.astro/
# tipos autogenerados por Astro
**/src/env.d.ts
# estado local de wrangler (en cualquier app)
.wrangler/
**/.wrangler/
# caché de Turborepo (en cualquier nivel)
.turbo/
**/.turbo/

# --- Tests / cobertura ---
coverage/
**/coverage/
playwright-report/
test-results/
.nyc_output/

# --- Datos locales ---
# config generada de Scrapoxy (con credenciales)
docker/scrapoxy/scrapoxy_config.json
*.sqlite
*.db
pgdata_local/

# --- Editor / SO ---
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db

# --- Logs ---
*.log
npm-debug.log*
pnpm-debug.log*

# --- Claude Code (estado local) ---
.claude/scheduled_tasks.lock

# --- Obsidian: workspace local del vault (la config compartida SÍ se versiona) ---
docs/.obsidian/workspace.json
docs/.obsidian/workspace-mobile.json
docs/.obsidian/cache
