# =====================================================================
# .env.example — Loto Honduras Analytics
# Copia a ".env" (NO versionado) con valores reales locales.
# NUNCA pongas secretos reales en este archivo de ejemplo.
# Reglas: ai-software-governance/08_DevOps/Secrets_Management.md
# =====================================================================

# --- Aplicación ---
APP_ENV=local                 # local | test | staging | production
APP_PORT=8787                 # puerto por defecto de wrangler dev (backend Hono)

# --- Base de datos: Desarrollo (Postgres en Docker) ---
# Estas tres las consume docker/docker-compose.yml para crear el contenedor.
POSTGRES_USER=dev_user
POSTGRES_PASSWORD=change-me-in-real-env
POSTGRES_DB=loto_analytics_dev
# Y esta la consumen las apps (debe concordar con las tres de arriba).
DATABASE_URL=postgres://dev_user:change-me-in-real-env@localhost:5432/loto_analytics_dev

# --- Base de datos: Producción (Neon serverless) ---
# Driver @neondatabase/serverless sobre WebSockets. Usar solo en prod/staging.
NEON_DATABASE_URL=postgres://USER:CHANGE_ME@ep-xxxx.neon.tech/loto_analytics?sslmode=require

# --- Autenticación (JWT Edge) ---
JWT_SECRET=change-me-in-real-env
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# --- Stripe (suscripciones online) — usar SIEMPRE claves de TEST en local ---
STRIPE_API_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxx

# --- Scrapoxy (proxy rotativo para ingestión) ---
SCRAPOXY_URL=http://localhost:8888
SCRAPOXY_AUTH_USERNAME=scraper_admin
SCRAPOXY_AUTH_PASSWORD=change-me-in-real-env

# --- Scraper / Ingestión ---
LOTERIA_SOURCE_URL=https://www.example-loto-honduras.hn   # URL objetivo del scraping

# --- Cloudflare (wrangler) ---
# Estos NO van en .env real: se gestionan con `wrangler secret put`.
# Se listan aquí solo para documentar qué secretos necesita cada Worker.
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=

# --- Observabilidad ---
LOG_LEVEL=debug               # debug | info | warn | error
